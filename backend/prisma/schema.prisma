generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums para garantir que apenas estes valores sejam aceitos
enum Role {
  ADMIN
  TECH
  CLIENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

model User {
  id             String    @id @default(uuid())
  name           String
  email          String    @unique
  password       String
  role           Role      @default(CLIENT)
  profileImage   String?   // URL da imagem de perfil (opcional)
  availableHours String[]  // Array de horários, ex: ["08:00", "09:00"]
  createdAt      DateTime  @default(now())

  // Relacionamentos
  ticketsAsClient Ticket[] @relation("ClientTickets")
  ticketsAsTech   Ticket[] @relation("TechTickets")
}

model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true) // SOFT DELETE: falso significa inativo, mas não perde histórico

  // Relação N:N com Chamados
  ticketServices TicketService[]
}

model Ticket {
  id          String       @id @default(uuid())
  status      TicketStatus @default(OPEN)
  totalValue  Decimal      @default(0.00) @db.Decimal(10, 2)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Chaves estrangeiras
  clientId    String
  techId      String?      // Pode ser nulo se o admin precisar atribuir depois, ou obrigatório na criação

  // Relacionamentos
  client      User         @relation("ClientTickets", fields: [clientId], references: [id], onDelete: Cascade) // Deleta os chamados se o cliente for excluido
  tech        User?        @relation("TechTickets", fields: [techId], references: [id])
  
  services    TicketService[]
}

// Tabela pivô para relação N:N entre Chamados e Serviços (permite add serviços depois)
model TicketService {
  id        String  @id @default(uuid())
  ticketId  String
  serviceId String
  priceAt   Decimal @db.Decimal(10, 2) // Grava o preço no momento do chamado, evitando alterações retroativas

  ticket    Ticket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id])
}